{
    "appId": "com.joao-graca.hardware-info",
    "productName": "Hardware Info",
    "files": [
        "dist-electron",
        "dist-react"
    ],
    "extraResources": [
        "dist-electron/preload.cjs",
        "src/assets/**"
    ],
    "icon": "./desktopIcon.png",
    "mac": {
        "target": "dmg"
    },
    "linux": {
        "artifactName": "hardware-info.${ext}",
        "target": "AppImage",
        "category": "Utility"
    },
    "win": {
        "artifactName": "hardware-info-${target}.${ext}",
        "target": [
            {
                "target": "portable",
                "arch": "x64"
            },
            {
                "target": "nsis",
                "arch": "x64"
            }
        ]
    }
}